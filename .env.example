# TrackMa — Environment Variables Template
# Copy to .env and fill in real values

# PostgreSQL
POSTGRES_DB=trackma
POSTGRES_USER=trackma
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://trackma:change-me-strong-password@localhost:5432/trackma

# Redis
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://localhost:6379

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (from Stripe Dashboard > Products)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=price_...

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@trackma.com

# Application URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WS_URL=ws://localhost:3001

NODE_ENV=development
